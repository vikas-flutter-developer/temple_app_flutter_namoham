# Server Configuration
PORT=3000

# Production URL (uncommented for production testing)
BASE_URL=https://temple-admin-website.onrender.com/api

# Local Testing URL (using your computer's local Wi-Fi IP - currently commented out)
# BASE_URL=http://192.168.1.9:8000/api

# For Android Emulator testing (automatically handled if BASE_URL is set to localhost/127.0.0.1 in app_config.dart, but documented here):
# BASE_URL=http://10.0.2.2:8000/api
# For Physical Mobile Device testing (using system IP):
# BASE_URL=http://192.168.1.9:8000/api

# Database Configuration


# Backend uses service_role key

# Flutter app uses anon key

SUPABASE_BUCKET=media

# Admin Credentials (for development auto-fill)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123