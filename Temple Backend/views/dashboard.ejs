<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
        }
        h1 {
            text-align: center;
        }
        .carousel-container {
            width: 80%;
            margin-bottom: 20px;
        }
        .carousel {
            display: flex;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
        }
        .carousel img {
            width: 200px;
            height: 200px;
            object-fit: cover;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            scroll-snap-align: center;
            margin-right: 10px;
        }
        .username {
            text-align: center;
            font-weight: bold;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>
    <h1>Welcome to the Dashboard!</h1>
    <% creatorData.forEach(creator => { %>
        <div class="carousel-container">
            <div class="username"><%= creator.username %></div>
            <div class="carousel">
                <% creator.pics.forEach(pic => { %>
                    <img src="<%= pic %>" alt="Creator Picture">
                <% }) %>
            </div>
        </div>
    <% }) %>
</body>
</html>