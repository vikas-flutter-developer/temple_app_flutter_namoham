
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .container {
            background-color: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            width: 400px;
        }
        h1, h2 {
            text-align: center;
        }
        form {
            display: none;
        }
        .form-active {
            display: block;
        }
        .form-group {
            margin-bottom: 15px;
        }
        .form-group label {
            display: block;
            margin-bottom: 5px;
        }
        .form-group input, .form-group select {
            width: 100%;
            padding: 8px;
            box-sizing: border-box;
        }
        button {
            width: 100%;
            padding: 10px;
            background-color: #007BFF;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        button:hover {
            background-color: #0056b3;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Registration</h1>
        <div class="form-group">
            <label for="userType">Select User Type:</label>
            <select id="userType" onchange="showForm()">
                <option value="">--Select--</option>
                <option value="user">User</option>
                <option value="temple">Temple</option>
                <option value="creator">Creator</option>
            </select>
        </div>

        <form id="userForm" action="/register/user" method="POST" class="form-active">
            <h2>User Registration</h2>
            <div class="form-group">
                <label for="profilePic">Profile Picture:</label>
                <input type="file" name="profilePic" required>
            </div>
            <div class="form-group">
                <label for="fullName">Full Name:</label>
                <input type="text" name="fullName" required>
            </div>
            <div class="form-group">
                <label for="email">Email:</label>
                <input type="email" name="email" required>
            </div>
            <div class="form-group">
                <label for="dob">Date of Birth:</label>
                <input type="date" name="dob" required>
            </div>
            <div class="form-group">
                <label for="password">Password:</label>
                <input type="password" name="password" required>
            </div>
            <div class="form-group">
                <label for="confirmPassword">Confirm Password:</label>
                <input type="password" name="confirmPassword" required>
            </div>
            <div class="form-group">
                <label for="phoneNumber">Phone Number:</label>
                <input type="text" name="phoneNumber" required>
            </div>
            <button type="submit">Register</button>
        </form>

        <form id="templeForm" action="/register/temple" method="POST">
            <h2>Temple Registration</h2>
            <div class="form-group">
                <label for="templePics">Temple Pictures:</label>
                <input type="file" name="templePics" multiple required>
            </div>
            <div class="form-group">
                <label for="templeName">Temple Name:</label>
                <input type="text" name="templeName" required>
            </div>
            <div class="form-group">
                <label for="email">Email:</label>
                <input type="email" name="email" required>
            </div>
            <div class="form-group">
                <label for="address">Address:</label>
                <input type="text" name="address" required>
            </div>
            <div class="form-group">
                <label for="zipCode">Zip Code:</label>
                <input type="text" name="zipCode" required>
            </div>
            <div class="form-group">
                <label for="state">State:</label>
                <input type="text" name="state" required>
            </div>
            <div class="form-group">
                <label for="establishmentDate">Establishment Date:</label>
                <input type="date" name="establishmentDate" required>
            </div>
            <div class="form-group">
                <label for="userId">User ID:</label>
                <input type="text" name="userId" required>
            </div>
            <div class="form-group">
                <label for="website">Website (optional):</label>
                <input type="url" name="website">
            </div>
            <div class="form-group">
                <label for="password">Password:</label>
                <input type="password" name="password" required>
            </div>
            <div class="form-group">
                <label for="pocPhoneNumber">POC Phone Number:</label>
                <input type="text" name="pocPhoneNumber" required>
            </div>
            <h3>Bank Details</h3>
            <div class="form-group">
                <label for="bankDetails.accountHolderName">Account Holder Name:</label>
                <input type="text" name="bankDetails.accountHolderName" required>
            </div>
            <div class="form-group">
                <label for="bankDetails.bankAccountNumber">Bank Account Number:</label>
                <input type="text" name="bankDetails.bankAccountNumber" required>
            </div>
            <div class="form-group">
                <label for="bankDetails.ifscCode">IFSC Code:</label>
                <input type="text" name="bankDetails.ifscCode" required>
            </div>
            <div class="form-group">
                <label for="bankDetails.bankName">Bank Name:</label>
                <input type="text" name="bankDetails.bankName" required>
            </div>
            <button type="submit">Register</button>
        </form>

        <form id="creatorForm" action="/register/creator" method="POST">
            <h2>Creator Registration</h2>
            <div class="form-group">
                <label for="creatorPics">Creator Pictures:</label>
                <input type="file" name="creatorPics" multiple required>
            </div>
            <div class="form-group">
                <label for="creatorName">Creator Name:</label>
                <input type="text" name="creatorName" required>
            </div>
            <div class="form-group">
                <label for="email">Email:</label>
                <input type="email" name="email" required>
            </div>
            <div class="form-group">
                <label for="address">Address:</label>
                <input type="text" name="address" required>
            </div>
            <div class="form-group">
                <label for="zipCode">Zip Code:</label>
                <input type="text" name="zipCode" required>
            </div>
            <div class="form-group">
                <label for="state">State:</label>
                <input type="text" name="state" required>
            </div>
            <div class="form-group">
                <label for="dob">Date of Birth:</label>
                <input type="date" name="dob" required>
            </div>
            <div class="form-group">
                <label for="userId">User ID:</label>
                <input type="text" name="userId" required>
            </div>
            <div class="form-group">
                <label for="phoneNumber">Phone Number:</label>
                <input type="text" name="phoneNumber" required>
            </div>
            <div class="form-group">
                <label for="password">Password:</label>
                <input type="password" name="password" required>
            </div>
            <button type="submit">Register</button>
        </form>
    </div>

    <script>
        function showForm() {
            const userType = document.getElementById('userType').value;
            document.getElementById('userForm').classList.remove('form-active');
            document.getElementById('templeForm').classList.remove('form-active');
            document.getElementById('creatorForm').classList.remove('form-active');

            if (userType === 'user') {
                document.getElementById('userForm').classList.add('form-active');
            } else if (userType === 'temple') {
                document.getElementById('templeForm').classList.add('form-active');
            } else if (userType === 'creator') {
                document.getElementById('creatorForm').classList.add('form-active');
            }
        }
    </script>
</body>
</html>